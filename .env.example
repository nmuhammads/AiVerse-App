# Kie.ai API Configuration
KIE_API_KEY=your_kie_ai_api_key_here

# PiAPI Configuration (Backup for NanoBanana Pro)
PIAPI_API_KEY=your_piapi_api_key_here

# My API Configuration (additional route for NanoBanana 2/Pro)
MY_API_BASE_URL=https://gemini-auto-manager-production.up.railway.app
MY_API_KEY=your_my_api_key_here
# Optional request timeout in ms (default: 45000)
# MY_API_TIMEOUT_MS=45000

# Application Configuration
NODE_ENV=development
PORT=3000

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-app-url.com/webhook

# Frontend Configuration (Vite - must start with VITE_)
VITE_TELEGRAM_BOT_NAME=AiVerseAppBot

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Payments feature flags
TRIBUTE_TOKEN_CHARGING_ENABLED=false
